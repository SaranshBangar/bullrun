{
  "name": "bullrun",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy -c dist/bullrun/wrangler.json",
    "check": "node --experimental-strip-types test/check.ts",
    "db:local": "wrangler d1 migrations apply bullrun --local",
    "db:remote": "wrangler d1 migrations apply bullrun --remote"
  },
  "dependencies": {
    "@better-auth/core": "^1.6.19",
    "@better-auth/infra": "^0.2.14",
    "@better-auth/sso": "^1.6.19",
    "better-auth": "^1.6.19",
    "gifenc": "^1.0.3",
    "kysely": "^0.28.5",
    "kysely-d1": "^0.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.12",
    "@cloudflare/workers-types": "^4.20250109.0",
    "better-sqlite3": "^12.11.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
